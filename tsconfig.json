{
	"compilerOptions": {
		"target": "ESNext",
		"module": "commonjs",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"allowSyntheticDefaultImports": true,
		"outDir": "./dist",

		"baseUrl": ".",
		"paths": {
			"@components/*": ["./src/components/*"],
			"@interactions/*": ["./src/interactions/*"],
			"@events/*": ["./src/events/*"]
		}
	}
}
